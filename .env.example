# ──────────────────────────────────────────────
#  IABilling — Environment Configuration
#  Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# MySQL Database
# For LOCAL MySQL (no Docker):
#   DATABASE_URL="mysql://root:yourpassword@localhost:3306/iabilling"
# For Docker MySQL:
#   DATABASE_URL="mysql://iabilling:iabilling_secret@mysql:3306/iabilling"

DB_ROOT_PASSWORD=
DB_USER=root
DB_NAME=iabilling
DB_HOST=localhost
DB_PORT=3306

DATABASE_URL="mysql://root:yourpassword@localhost:3306/iabilling"

# Backend
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_EXPIRES_IN=7d
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:5000/api
